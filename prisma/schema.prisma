generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  ext_expires_in    Int?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  sshPublicKey  String?
  accounts      Account[]
  sessions      Session[]
  groups        GroupMember[]
  instances     Instance[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Group {
  id           String        @id @default(cuid())
  name         String        @unique
  description  String?
  isAdmin      Boolean       @default(false)
  maxRamMb     Int           @default(512)
  maxCpuCores  Int           @default(1)
  maxDiskGb    Int           @default(8)
  maxInstances Int           @default(1)
  maxSwapMb    Int           @default(0)
  members      GroupMember[]
  instances    Instance[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model GroupMember {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, groupId])
}

model Instance {
  id         String     @id @default(cuid())
  vmid       Int        @unique
  name       String
  userId     String
  groupId    String
  ramMb      Int
  cpuCores   Int
  diskGb     Int
  swapMb     Int        @default(0)
  osTemplate String
  node       String
  status     String     @default("creating")
  user       User       @relation(fields: [userId], references: [id])
  group      Group      @relation(fields: [groupId], references: [id])
  ip         IpAddress?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Settings {
  id        String   @id @default("global")
  storage   String   @default("local-lvm")
  bridge    String   @default("vmbr0")
  updatedAt DateTime @updatedAt
}

model OsTemplate {
  id        String   @id @default(cuid())
  name      String
  template  String   @unique
  createdAt DateTime @default(now())
}

model IpRange {
  id           String      @id @default(cuid())
  label        String?
  gateway      String
  startIp      String?
  endIp        String?
  isIndividual Boolean     @default(false)
  addresses    IpAddress[]
  createdAt    DateTime    @default(now())
}

model IpAddress {
  id         String    @id @default(cuid())
  address    String    @unique
  gateway    String
  ipRangeId  String
  instanceId String?   @unique
  ipRange    IpRange   @relation(fields: [ipRangeId], references: [id], onDelete: Cascade)
  instance   Instance? @relation(fields: [instanceId], references: [id])
  createdAt  DateTime  @default(now())
}
